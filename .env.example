# === The Tower — Environment Variables ===
# Copy to .env.local and fill in values. NEVER commit .env.local.

# --- Phase 0: Foundation ---

# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...  # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # service role (server-only, never expose)
SUPABASE_DB_URL=postgresql://...              # direct connection for Drizzle migrations

# Google OAuth (via Supabase Auth)
# Configure in Google Cloud Console > Credentials > OAuth 2.0 Client ID
# Redirect URI: https://your-project.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phase 1: Agents ---

# Anthropic (AI SDK v6 provider)
ANTHROPIC_API_KEY=sk-ant-...

# --- Phase 2: Background Jobs + Email ---

# Inngest (background job orchestration)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (outreach email delivery)
RESEND_API_KEY=re_...

# --- Phase 6: Monetization + Polish ---

# Stripe (subscriptions)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Upstash Redis (rate limiting + caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenWeatherMap (weather-reactive skyline, optional)
OPENWEATHER_API_KEY=
