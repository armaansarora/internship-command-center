# === The Tower — Environment Variables ===
# Copy to .env.local and fill in values. NEVER commit .env.local.

# --- Phase 0: Foundation ---

# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Google OAuth (Tower login + Gmail/Calendar)
# Configure in Google Cloud Console > Credentials > OAuth 2.0 Client ID
# Authorized JavaScript origin: https://www.interntower.com
# Supabase provider redirect URI: https://your-project.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# HMAC secret for OAuth state parameter (32+ random bytes, base64 or hex).
# Generate: openssl rand -base64 48
OAUTH_STATE_SECRET=

# --- Phase 1: Agents ---

# Anthropic (AI SDK provider)
ANTHROPIC_API_KEY=

# --- Phase 2: Background Jobs + Email ---

# Cron sync security (Vercel Cron auto-authenticates; set this for external triggers).
# REQUIRED in production — fail-closed cron auth is enforced (audit C-1).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# OAuth `state` HMAC signing secret (for Gmail/Calendar callback verification).
# If unset, falls back to CRON_SECRET. Recommended to set independently in prod.
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# App URL (for cron sync self-calls)
NEXT_PUBLIC_APP_URL=

# Gmail OAuth (Phase 2 — Gmail/Calendar/Drive integration).
# REQUIRED before any /api/gmail/* or /api/calendar/* call.
# Must match the redirect URI configured in Google Cloud Console.
# Local: http://localhost:3000/api/gmail/callback
# Prod:  https://www.interntower.com/api/gmail/callback
GMAIL_REDIRECT_URI=

# AES-256-GCM key for encrypting Gmail/Calendar OAuth tokens at rest.
# REQUIRED — Gmail OAuth flow throws on first use otherwise (audit H-6).
# Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Resend (transactional/export/outreach email delivery).
RESEND_API_KEY=

# --- Phase 3: pgvector + Embeddings ---

# Preferred: Vercel AI Gateway for agents, embeddings, and provider analytics.
AI_GATEWAY_API_KEY=

# Optional fallback: direct OpenAI key for embeddings/voice when Gateway is unset.
OPENAI_API_KEY=

# --- Phase 6: Monetization + Polish ---

# Stripe (subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Upstash Redis (rate limiting + caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenWeatherMap (weather-reactive skyline, optional)
OPENWEATHER_API_KEY=

# --- Observability ---

# Sentry (error tracking + source maps).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Required only at build time for source-map upload (CI / Vercel build env).
SENTRY_AUTH_TOKEN=

# Plausible (privacy-first analytics). Script is disabled when unset.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- R4 LinkedIn OAuth (optional — unblocks R4 B1) ---
# Not required for R4 acceptance; when unset, LinkedIn sync is simply unavailable.
# Configure at https://www.linkedin.com/developers/ → Create app → Auth tab.
# Redirect URI: https://www.interntower.com/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- R6 Voice transcription ---
# Used by /api/briefing/audio-upload when voice_recording_enabled=true on the
# user's profile. Uses AI_GATEWAY_API_KEY when present; otherwise OPENAI_API_KEY.

# R10 — Firecrawl API key for Levels.fyi comp-band scraping.
# Free tier: 500 credits/month. 30-day cache keeps us well under cap.
# Get one at https://firecrawl.dev → API Keys
FIRECRAWL_API_KEY=<your-firecrawl-api-key>
