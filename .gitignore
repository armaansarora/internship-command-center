# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
migration-*.sql

# husky internal directory
.husky/_/

# audit reports — contain detailed vulnerability findings; keep local-only for public repo
# Root-anchored so src/lib/audit/ (the runtime security-event helper) is tracked.
/audit/

# editor configs
.vscode/

# Playwright — local artifacts only, never commit.
test-results/
playwright-report/

# Stripe bootstrap script output — contains webhook secret
.stripe-ids.json
.env*.local

# Per-developer Claude Code config (skills, local permissions). The skills here
# are re-installable via `playwright-cli install --skills`; settings.local.json
# holds developer-specific permission grants and must not be shared.
.claude/

# Per-developer Codex/agent config (local runtime permissions).
.agents/*
!.agents/skills/
.agents/skills/*
!.agents/skills/creative-production-engine/
!.agents/skills/creative-production-engine/**

# playwright-cli session artifacts — page snapshots, console logs, screenshots.
.playwright-cli/

# Tower Creative Production Engine keeps heavy generated workshop binaries local.
# Production-ready optimized assets are committed from public/art instead.
.artlab/characters/**/masters/
.artlab/characters/**/qa/
.artlab/characters/**/references/
.artlab/characters/**/staged-public/
.artlab/studio/**/promotion/masters/
.artlab/studio/**/promotion/qa/
.artlab/studio/**/promotion/staged-public/
.artlab/runs/**/incoming/
.artlab/runs/**/split/
.artlab/runs/**/browser-qa/*.png
.artlab/runs/**/review/*.png
.artlab/inbox/
.artlab/browser-sessions/**/browser-profile/
.artlab/browser-sessions/**/chrome-profile/
.artlab/browser-sessions/**/downloads/
.artlab/browser-sessions/**/queue/
.artlab/tooling/cutout/models/
.artlab/tooling/cutout/venv/

# artlab transient workspace (only .gitkeep files tracked)
.artlab/engine/runs/**/run-state.json
.artlab/engine/runs/**/progress.json
.artlab/engine/runs/**/events.jsonl
.artlab/engine/slot-leases/*.lease.json
.artlab/engine/inbox/**/*.json
.artlab/engine/ledgers/*.jsonl
.artlab/engine/memory/*.jsonl
