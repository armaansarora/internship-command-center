# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
migration-*.sql

# husky internal directory
.husky/_/

# audit reports — contain detailed vulnerability findings; keep local-only for public repo
# Root-anchored so src/lib/audit/ (the runtime security-event helper) is tracked.
/audit/

# editor configs
.vscode/

# Playwright — local artifacts only, never commit.
test-results/
playwright-report/

# Stripe bootstrap script output — contains webhook secret
.stripe-ids.json
.env*.local
