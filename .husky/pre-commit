# Auto-organize docs: archive stale, regenerate CLAUDE.md components, update doc map, append session log
npx tsx scripts/auto-organize-docs.ts 2>/dev/null
for f in CLAUDE.md PROJECT-CONTEXT.md; do
  [ -f "$f" ] && git add "$f" 2>/dev/null
done
git add docs/ 2>/dev/null

# Auto-regenerate BOOTSTRAP-PROMPT.md
npx tsx scripts/generate-bootstrap.ts 2>/dev/null
git add BOOTSTRAP-PROMPT.md

# Validate .tower/autopilot.yml before letting the commit through.
# Catches R4-class timestamp drift (ended < started), bad scope format, etc.
npx tsx scripts/tower/index.ts lint-autopilot --strict || {
  echo "✗ autopilot.yml has semantic issues — fix before committing"
  exit 1
}

# Phase Ledger drift check — warn-only, never blocks a commit
npx tsx scripts/ledger/verify.ts --warn-only || true
