    {
      "name": "flat-chroma-source-preflight",
      "command": "npm run art:preflight -- <source-file> --minimum-long-edge 4096 --chroma-key 00ff00 --json",
      "condition": "Only for temporary chroma-key sources."
    }
  ],
  "manualVisualChecks": [
    "dark background halo check",
    "light background halo check",
    "checkerboard alpha edge check",
    "warm lobby lighting preview",
